{
  "name": "rust-supervisor-ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vue-tsc --noEmit && vite build",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "test:e2e": "VITE_SUPERVISOR_RELAY_URL=wss://127.0.0.1:9443/supervisor npm run build && VITE_SUPERVISOR_RELAY_URL=wss://127.0.0.1:9443/supervisor playwright test",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@vue-flow/background": "^1.3.2",
    "@vue-flow/controls": "^1.1.3",
    "@vue-flow/core": "^1.41.1",
    "@vueuse/core": "^14.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-vue-next": "^0.468.0",
    "reka-ui": "^2.9.7",
    "tailwind-merge": "^2.6.0",
    "vue": "^3.5.13",
    "vue-i18n": "^11.4.2",
    "vue-sonner": "^2.0.9"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@types/node": "^22.10.2",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.20",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vitest": "^4.1.5",
    "vue-tsc": "^2.1.10"
  }
}
